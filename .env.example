# Hotel AI Email Agent Configuration

# Required: Your Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Execution Mode: "human" (waits for approval) or "autonomous" (executes immediately)
APPROVAL_MODE=human

# LLM Configuration
LLM_MODEL=claude-haiku-4-5
LLM_MAX_TOKENS=2048
AGENT_MAX_ITERATIONS=10

# Mock date for testing cancellation windows and availability (YYYY-MM-DD)
MOCK_CURRENT_DATE=2025-04-18
